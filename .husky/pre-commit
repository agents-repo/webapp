#!/usr/bin/env bash

# Load nvm if available (GUI/non-interactive shells often skip shell rc files).
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  # shellcheck source=/dev/null
  . "$NVM_DIR/nvm.sh"
  nvm use --silent >/dev/null 2>&1 || true
fi

run_lint_checks_npm() {
  npm run lint:all
}

run_lint_checks_corepack() {
  corepack npm run lint:all
}

if command -v npm >/dev/null 2>&1; then
  run_lint_checks_npm
  exit $?
fi

if command -v corepack >/dev/null 2>&1; then
  run_lint_checks_corepack
  exit $?
fi

echo "[husky] npm not found in PATH; skipping lint:all in this environment." >&2
exit 0
