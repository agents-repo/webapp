#!/usr/bin/env bash

# Load nvm if available (GUI/non-interactive shells often skip shell rc files).
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  # shellcheck source=/dev/null
  . "$NVM_DIR/nvm.sh"
  nvm use --silent >/dev/null 2>&1 || true
fi

run_checks() {
  if command -v corepack >/dev/null 2>&1; then
    corepack npm run lint:all || return $?
    corepack npm run test:sync || return $?
    corepack npm run sync:cursor-rules -- --check
  else
    npm run lint:all || return $?
    npm run test:sync || return $?
    npm run sync:cursor-rules -- --check
  fi
}

if command -v corepack >/dev/null 2>&1 || command -v npm >/dev/null 2>&1; then
  run_checks
  exit $?
fi

echo "[husky] corepack and npm not found in PATH; skipping pre-commit checks in this environment." >&2
exit 0
