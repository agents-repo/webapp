# E2E build env — alias-free registry URLs for deterministic Playwright tests.
# Template for `.env.e2e`. Vite loads `.env.e2e` when building with `--mode e2e`
# (see `build:pages:e2e`). This `.example` file is not loaded automatically.
# The repo commits `.env.e2e`; copy this file only to recreate it locally.

VITE_E2E_BUILD=true
VITE_REGISTRY_BASE_URL=https://e2e.local/registry
VITE_REGISTRY_GITHUB_REPOSITORY_URL=https://github.com/agents-repo/registry/tree/main
VITE_REGISTRY_INDEX_PATH=packages/index.json
