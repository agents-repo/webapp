{
  "name": "agents-repo-webapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "24.18.0"
  },
  "packageManager": "npm@12.0.1",
  "scripts": {
    "dev": "vite",
    "env:check": "node scripts/validate-env.mjs",
    "build": "tsc -b && vite build && node scripts/remove-e2e-build-marker.mjs",
    "build:pages": "npm run build && node --experimental-strip-types scripts/prepare-pages-dist.mjs",
    "build:pages:e2e": "tsc -b && vite build --mode e2e && node --experimental-strip-types scripts/prepare-pages-dist.mjs && node scripts/write-e2e-build-marker.mjs",
    "release:dry-run": "semantic-release --dry-run",
    "lint": "eslint .",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"**/.*/**/*.md\"",
    "lint:all": "npm run lint:md && npm run lint",
    "sync:cursor-rules": "node scripts/sync-cursor-rules.mjs",
    "test:sync": "node --test test/sync-cursor-rules.test.mjs",
    "test:crawl-files": "node --experimental-strip-types --test test/crawl-files.integration.test.mjs",
    "test": "npm run test:sync && npm run test:crawl-files && vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:a11y": "npm run test:sync && npm run test:crawl-files && vitest run --config vitest.a11y.config.ts",
    "a11y:ci": "node scripts/run-a11y-ci.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.e2e.json",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-brands-svg-icons": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/react-fontawesome": "^3.4.0",
    "bootstrap": "^5.3.8",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.18.1",
    "semver": "^7.8.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "markdownlint-cli2": "^0.23.0",
    "pa11y-ci": "^4.1.1",
    "sass": "^1.101.0",
    "semantic-release": "^25.0.6",
    "serve": "^14.2.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-sitemap": "^0.8.2",
    "vitest": "^4.1.10",
    "vitest-axe": "^0.1.0"
  },
  "overrides": {
    "undici@^6": "^6.27.0",
    "undici@^7": "^7.28.0",
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    }
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "puppeteer@24.43.1": true
  }
}
